meta {
  name: get-orders
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/orders
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is an array of orders", function() {
    expect(res.getBody()).to.be.an("array");
  });
}
