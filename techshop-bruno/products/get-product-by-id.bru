meta {
  name: get-product-by-id
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/products/1
  body: none
  auth: none
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Returns the correct product", function() {
    expect(res.getBody().id).to.equal(1);
  });
}
