meta {
  name: get-products
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/products
  body: none
  auth: none
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is an array of products", function() {
    expect(res.getBody()).to.be.an("array");
  });
}
