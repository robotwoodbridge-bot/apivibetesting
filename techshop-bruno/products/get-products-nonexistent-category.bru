meta {
  name: get-products-nonexistent-category
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/products?category=nonexistent-category
  body: none
  auth: none
}

params:query {
  category: nonexistent-category
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is an empty array", function() {
    expect(res.getBody()).to.be.an("array").that.is.empty;
  });
}
