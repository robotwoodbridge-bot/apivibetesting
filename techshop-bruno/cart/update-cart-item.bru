meta {
  name: update-cart-item
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/cart/{{cartItemId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
  Content-Type: application/json
}

body:json {
  {
    "quantity": 3
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
