meta {
  name: add-to-cart-invalid-quantity
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/cart
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{authToken}}
  Content-Type: application/json
}

body:json {
  {
    "productId": 1,
    "quantity": 0
  }
}

tests {
  test("Status code is 400 (invalid quantity)", function() {
    expect(res.getStatus()).to.equal(400);
  });
}
